# Database (for local run when Postgres is in docker-compose)
DB_URL=jdbc:postgresql://localhost:5432/meals
DB_USER=meals
DB_PASSWORD=meals

# Backend
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Frontend (when running Node server locally)
# BACKEND_URL=http://localhost:8080
# PORT=3000

# Frontend dev (Vite proxy targets backend; optional override)
# VITE_API_URL=

# Auth (optional; for production set JWT_SECRET)
# JWT_SECRET=your-secret-at-least-32-chars
# Disable auth for local development only (do not set in production)
# DISABLE_AUTH=true
# VITE_DISABLE_AUTH=true
