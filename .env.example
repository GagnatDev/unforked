# Database (for local run when Postgres is in docker-compose)
DATABASE_URL=postgresql://meals:meals@localhost:5432/meals

# Backend
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Frontend (when running Node server locally)
# BACKEND_URL=http://localhost:8080
# PORT=3000

# Frontend dev (Vite proxy targets backend; optional override)
# VITE_API_URL=

# Auth: production identity comes from the homectl-auth sidecar's headers.
# Locally there is no sidecar - disable auth to use the fixed dev admin
# (do not set in production):
# DISABLE_AUTH=true

# One-time homectl-auth user import at boot (set all three or none; production
# gets them from the unforked-terraform-secrets Secret):
# AUTH_CLIENT_ID=unforked
# AUTH_CLIENT_SECRET=...
# INTERNAL_AUTH_URL=http://homectl-auth.homectl
