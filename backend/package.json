{
  "name": "@unforked/backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "unforked-backend": "dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e:server": "tsx src/e2e-server.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "kysely": "^0.27.4",
    "node-pg-migrate": "^7.9.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vitest": "^3.2.4"
  }
}
